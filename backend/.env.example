# ===========================================
# Configuración de Base de Datos MySQL
# ===========================================
DB_HOST=192.168.20.205
DB_PORT=3306
DB_USER=usuario_juridica
DB_PASSWORD=clave_juridica_123
DB_NAME=Juridica
# Opcional: si los permisos del usuario están detrás de un rol MySQL 8.
DB_ACTIVATE_ROLE=

# ===========================================
# Seguridad / JWT
# ===========================================
# IMPORTANTE: Cambia esta clave en producción. Genera una con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambia-esta-clave-en-produccion-usa-un-token-largo-y-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===========================================
# Admin inicial (se crea automáticamente)
# ===========================================
ADMIN_USERNAME=gerencia2026*
ADMIN_PASSWORD=gerencia2026*

# ===========================================
# Servidor
# ===========================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
# IP o dominio por el que otros PCs acceden (no uses localhost en red).
APP_PUBLIC_URL=http://192.168.20.177:8000


# ===========================================
# Uploads
# ===========================================
UPLOAD_DIR=../uploads
MAX_UPLOAD_SIZE_MB=25

# ===========================================
# SMTP — Notificaciones JURICOM_BEEF
# ===========================================
SMTP_HOST=mail.colbeef.com.co
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=no-responder-sirt@colbeef.com.co
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-responder-sirt@colbeef.com.co
SMTP_FROM_NAME=JURICOM_BEEF

# Destinatarios fijos (separados por coma).
JURIDICA_EMAILS=coordinacion.juridica@colbeef.com,gerencia.juridica@colbeef.com
COMPRAS_EMAILS=

# Flujo de aprobación al radicar: líder inmediato → gerencia.
LIDER_INMEDIATO_EMAIL=coordinacion.juridica@colbeef.com
GERENCIA_EMAIL=tommyelite25@gmail.com
